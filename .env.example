# Application
APP_NAME=yougo-brain
NODE_ENV=development
PORT=8001

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yougo_brain?schema=public"

# Cache (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379

# Logging
LOG_LEVEL=info

# Observability
OBSERVABILITY_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com
