# Application Configuration
APP_NAME=yougo-brain
# Set to 'development' for local testing (enables mock failbacks if keys are missing)
# Set to 'production' for live deployments (requires active API keys, throws on missing keys)
NODE_ENV=development
PORT=8001

# Database Configuration (PostgreSQL)
# Local Dev Default: "postgresql://postgres:postgres@localhost:5432/yougo_brain?schema=public"
# Production: Use your Neon PostgreSQL connection string (make sure to append ?schema=yougo_brain or use default schema)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yougo_brain?schema=public"

# Cache Configuration (Redis)
# Local Dev Default: Host "localhost", Port 6379, or URL "redis://localhost:6379"
# Production: Use your shared Railway Redis connection URL (REDIS_URL)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379"

# Logging & Telemetry
LOG_LEVEL=info
OBSERVABILITY_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# Third-Party API Keys (Required for Dynamic Itineraries)
# Note: In production, configure these as Environment Variables on your Render Dashboard!
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"
FALLBACK_GROQ_API_KEY="YOUR_FALLBACK_GROQ_API_KEY_HERE"
OPEN_ROUTE_SERVICE_KEY="YOUR_OPEN_ROUTE_SERVICE_KEY_HERE"
UNSPLASH_API_KEY="YOUR_UNSPLASH_API_KEY_HERE"
PEXELS_API_KEY="YOUR_PEXELS_API_KEY_HERE"
